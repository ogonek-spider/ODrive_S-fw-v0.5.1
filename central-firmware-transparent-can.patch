 #include "usbtwai.h"
 #include <memory.h>
 #include "esp_task.h"
+#include <stdlib.h>
+
+static int hexNibble(char value) {
+    if (value >= '0' && value <= '9') return value - '0';
+    if (value >= 'A' && value <= 'F') return value - 'A' + 10;
+    if (value >= 'a' && value <= 'f') return value - 'a' + 10;
+    return -1;
+}
+
+static bool parseSlcanFrame(const char* input, twaiFrameWithBuffer& frame) {
+    if (!input || input[0] != 't') return false;
+
+    char idString[4] = {input[1], input[2], input[3], '\0'};
+    char* idEnd = nullptr;
+    unsigned long id = strtoul(idString, &idEnd, 16);
+    int dlc = hexNibble(input[4]);
+    if (!idEnd || *idEnd != '\0' || id > 0x7ff || dlc < 0 || dlc > 8) {
+        return false;
+    }
+
+    frame.frame.header.id = id;
+    frame.frame.header.dlc = dlc;
+    frame.frame.buffer_len = dlc;
+    for (int i = 0; i < dlc; ++i) {
+        int high = hexNibble(input[5 + i * 2]);
+        int low = hexNibble(input[6 + i * 2]);
+        if (high < 0 || low < 0) return false;
+        frame.buffer[i] = (high << 4) | low;
+    }
+    return true;
+}
 
